# ── AI: Google Gemini ────────────────────────────────────────────────────────
# Lấy free tại: aistudio.google.com → Get API key
# Thiếu key: app vẫn chạy nhưng mọi feature AI (draft, chat, transcribe) tắt
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-2.0-flash-lite   # default nếu bỏ trống

# ── n8n webhook security ─────────────────────────────────────────────────────
# ⚠️ Bỏ trống = webhook KHÔNG có auth (fail-open). Production bắt buộc phải set.
ZAPIER_WEBHOOK_SECRET=your-secret-here

# ── Database (tự tạo khi chạy lần đầu) ──────────────────────────────────────
# DATABASE_PATH=./data/brain.db
